# V1.6.17 local Ollama / DeepSeek-R1 8B generation profile.
# Copy these values into .env for local-dev. Do not commit real .env files.

AI_CHAT_PROVIDER=ollama
MODEL_PROVIDER_MODE=ollama
MODEL_API_BASE_URL=http://127.0.0.1:11434
MODEL_API_KEY=
MODEL_NAME=deepseek-r1:8b
MODEL_TIMEOUT_SECONDS=180
MODEL_MAX_RETRIES=1

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_MAX_RETRIES=1
OLLAMA_NUM_CTX=8192
OLLAMA_KEEP_ALIVE=10m
OLLAMA_THINK=true

RAG_GENERATION_PROVIDER=ollama
RAG_GENERATION_MODEL=deepseek-r1:8b
