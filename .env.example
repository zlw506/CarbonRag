APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

MODEL_PROVIDER_MODE=openai_compatible
# V1.6.16: default to a local OpenAI-compatible chat endpoint.
# Recommended first route: Ollama OpenAI-compatible API.
MODEL_API_BASE_URL=http://127.0.0.1:11434/v1
MODEL_API_KEY=ollama-local-key
MODEL_NAME=deepseek-r1:8b
MODEL_TEMPERATURE=0.2
MODEL_MAX_TOKENS=4096
MODEL_TIMEOUT_SECONDS=120

EMBEDDING_API_BASE_URL=https://api.example.com/v1
EMBEDDING_API_KEY=replace-with-embedding-api-key
EMBEDDING_MODEL=replace-with-embedding-model
# Only use openai_compatible embedding when this endpoint is a real /v1/embeddings API.
# A normal chat-completions API cannot replace an embedding model.
# Chat LLM != embedding model. RAG retrieval uses local BGE-M3 below.

RAG_ENGINE_ENABLED=true
RAG_VECTOR_ENABLED=true
RAG_VECTOR_BACKEND=milvus
RAG_REQUIRE_REAL_VECTOR=true
RAG_MILVUS_URI=http://127.0.0.1:19530
RAG_MILVUS_COLLECTION_PREFIX=carbonrag
RAG_EMBEDDING_PROVIDER=bge_m3
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_EMBEDDING_DEVICE=cpu
RAG_MODEL_CACHE_DIR=./data/outputs/models
RAG_MODEL_AUTO_DOWNLOAD=false
RAG_HF_ENDPOINT=https://hf-mirror.com
RAG_LANGCHAIN_ENABLED=true
RAG_BM25_ENABLED=true
RAG_HYDE_ENABLED=true
RAG_RERANK_ENABLED=true
RAG_RERANK_PROVIDER=bge_reranker
RAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
RAG_DEFAULT_MODE=mix
RAG_CHROMA_PERSIST_DIR=./data/outputs/chroma
RAG_CHROMA_COLLECTION=carbonrag_langchain
RAG_LANGCHAIN_CHUNK_SIZE=800
RAG_LANGCHAIN_CHUNK_OVERLAP=120
RAG_LANGCHAIN_DEFAULT_TOP_K=5
RAG_LANGSMITH_TRACING=false
RAG_PARSER_PROVIDER=default
RAG_ENABLE_MINERU=false
RAG_PARSER_FALLBACK_CHAIN=docling,mineru,default

DATABASE_URL=
MEMORY_BACKEND=sqlite
VECTOR_STORE_PATH=./data/outputs/vector_store
PUBLIC_DATA_DIR=./data/public
PRIVATE_SAMPLE_DIR=./data/private_sample
FACTOR_DATA_DIR=./data/factors
UPLOAD_DIR=./data/outputs/uploads
