APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

MODEL_API_BASE_URL=https://cli-proxy-api-latest-tqjw.onrender.com/v1
MODEL_API_KEY=replace-with-model-api-key
MODEL_NAME=gpt-5.4
MODEL_TEMPERATURE=0.2
MODEL_MAX_TOKENS=4096

EMBEDDING_API_BASE_URL=https://api.example.com/v1
EMBEDDING_API_KEY=replace-with-embedding-api-key
EMBEDDING_MODEL=replace-with-embedding-model

RAG_ENGINE_ENABLED=true
RAG_VECTOR_ENABLED=true
RAG_VECTOR_BACKEND=chroma
RAG_LANGCHAIN_ENABLED=true
RAG_BM25_ENABLED=true
RAG_HYDE_ENABLED=true
RAG_RERANK_ENABLED=true
RAG_RERANK_PROVIDER=cross_encoder
RAG_RERANK_MODEL=BAAI/bge-reranker-base
RAG_DEFAULT_MODE=mix
RAG_CHROMA_PERSIST_DIR=./data/outputs/chroma
RAG_CHROMA_COLLECTION=carbonrag_langchain
RAG_LANGCHAIN_CHUNK_SIZE=800
RAG_LANGCHAIN_CHUNK_OVERLAP=120
RAG_LANGCHAIN_DEFAULT_TOP_K=5
RAG_LANGSMITH_TRACING=false
RAG_PARSER_PROVIDER=default
RAG_ENABLE_MINERU=false
RAG_PARSER_FALLBACK_CHAIN=docling,mineru,default

DATABASE_URL=
MEMORY_BACKEND=sqlite
VECTOR_STORE_PATH=./data/outputs/vector_store
PUBLIC_DATA_DIR=./data/public
PRIVATE_SAMPLE_DIR=./data/private_sample
FACTOR_DATA_DIR=./data/factors
UPLOAD_DIR=./data/outputs/uploads
