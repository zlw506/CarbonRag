# CarbonRag V1.6.16 local chat LLM profile: vLLM OpenAI-compatible server
#
# Use when a local vLLM server is running and serving a DeepSeek-compatible model.
# Example service endpoint:
#   http://127.0.0.1:8001/v1
#
# Offline model package convention:
#   data/outputs/models/LLM/<deepseek-or-qwen-model>/

MODEL_PROVIDER_MODE=openai_compatible
MODEL_API_BASE_URL=http://127.0.0.1:8001/v1
MODEL_API_KEY=vllm-local-key
MODEL_NAME=deepseek-ai/DeepSeek-R1-Distill-Qwen-7B
MODEL_TEMPERATURE=0.2
MODEL_MAX_TOKENS=4096
MODEL_TIMEOUT_SECONDS=120

