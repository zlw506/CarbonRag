# CarbonRag V1.6.16 local chat LLM profile: Ollama + DeepSeek
#
# Use when Ollama is running locally and exposes the OpenAI-compatible endpoint.
# Model weights are local machine assets and must not be committed.
#
# Online install example:
#   ollama pull deepseek-r1:8b
#
# Offline package convention:
#   data/outputs/models/LLM/deepseek-r1-8b/
# Ask #1 for the offline model package if network download is slow or blocked.

MODEL_PROVIDER_MODE=openai_compatible
MODEL_API_BASE_URL=http://127.0.0.1:11434/v1
MODEL_API_KEY=ollama-local-key
MODEL_NAME=deepseek-r1:8b
MODEL_TEMPERATURE=0.2
MODEL_MAX_TOKENS=4096
MODEL_TIMEOUT_SECONDS=120

